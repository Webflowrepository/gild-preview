---
/**
 * Gallery.astro — Dense photo grid gallery
 * Layout: CSS Grid — dense multi-column grid showing many photos at once
 * Desktop: 4-5 columns of small thumbnails with rounded corners
 * Tablet: 3 columns
 * Mobile: 2 columns
 * Dark background, small gap, photos fill cells uniformly
 * NO carousels, NO bento grids, NO lightbox
 */

interface GalleryPhoto {
  src: string;
  alt: string;
  aspect: 'portrait' | 'wide' | 'square';
}

interface Props {
  eyebrow: string;
  photos: GalleryPhoto[];
}

const { eyebrow, photos } = Astro.props;
---

<section
  id="gallery"
  class="gallery-section"
  aria-label="Photo gallery"
>
  <div class="gallery-container">
    <p class="text-eyebrow gallery-eyebrow" style={`color: var(--color-fg-subtle);`}>
      {eyebrow}
    </p>

    <div class="gallery-grid">
      {photos.map((photo, i) => (
        <figure class="gallery-item">
          <img
            src={photo.src}
            alt={photo.alt}
            class="gallery-photo"
            loading={i < 8 ? 'eager' : 'lazy'}
            decoding="async"
          />
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery-section {
    padding: 64px 16px;
    background: var(--color-bg, #0a0a0a);
  }

  .gallery-container {
    max-width: 1440px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .gallery-eyebrow {
    text-align: center;
  }

  /* ── Dense grid: many small thumbnails ── */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 6px;
  }

  .gallery-item {
    margin: 0;
    padding: 0;
    overflow: hidden;
    border-radius: 6px;
  }

  .gallery-photo {
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    border-radius: 6px;
    filter: brightness(0.92) saturate(0.9);
    transition: filter 0.3s ease, transform 0.3s ease;
  }

  .gallery-photo:hover {
    filter: brightness(1) saturate(1);
    transform: scale(1.03);
  }

  /* ── Mobile: 2 columns ── */
  @media (max-width: 479px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 4px;
    }

    .gallery-section {
      padding: 48px 8px;
    }
  }

  /* ── Tablet: 3 columns ── */
  @media (min-width: 480px) and (max-width: 767px) {
    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 5px;
    }
  }

  /* ── Desktop: 4 columns ── */
  @media (min-width: 768px) and (max-width: 1023px) {
    .gallery-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 6px;
    }

    .gallery-section {
      padding: 96px 32px;
    }
  }

  /* ── Large desktop: 5 columns — dense like the reference ── */
  @media (min-width: 1024px) {
    .gallery-grid {
      grid-template-columns: repeat(5, 1fr);
      gap: 6px;
    }

    .gallery-section {
      padding: 96px 48px;
    }
  }

  /* ── Extra large: 6 columns ── */
  @media (min-width: 1440px) {
    .gallery-grid {
      grid-template-columns: repeat(6, 1fr);
      gap: 8px;
    }
  }
</style>

<script>
  import { animateFadeUp } from '../lib/gsap-utils';

  document.addEventListener('DOMContentLoaded', () => {
    animateFadeUp('.gallery-section', '.gallery-item', {
      stagger: 0.03,
    });
  });
</script>

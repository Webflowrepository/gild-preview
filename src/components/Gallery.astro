---
/**
 * Gallery.astro — Dense photo grid gallery with click-to-download overlay
 * Layout: CSS Grid — dense multi-column grid showing many photos at once
 * Desktop: 5-6 columns of small thumbnails with rounded corners
 * Tablet: 3-4 columns
 * Mobile: 2 columns
 * Click any photo → full-size overlay with download button
 */

interface GalleryPhoto {
  src: string;
  alt: string;
  aspect: 'portrait' | 'wide' | 'square';
}

interface Props {
  eyebrow: string;
  photos: GalleryPhoto[];
}

const { eyebrow, photos } = Astro.props;
---

<section
  id="gallery"
  class="gallery-section"
  aria-label="Photo gallery"
>
  <div class="gallery-container">
    <p class="text-eyebrow gallery-eyebrow" style={`color: var(--color-fg-subtle);`}>
      {eyebrow}
    </p>

    <div class="gallery-grid">
      {photos.map((photo, i) => (
        <figure class="gallery-item" data-src={photo.src} data-alt={photo.alt}>
          <img
            src={photo.src}
            alt={photo.alt}
            class="gallery-photo"
            loading={i < 8 ? 'eager' : 'lazy'}
            decoding="async"
          />
        </figure>
      ))}
    </div>
  </div>

  <!-- Overlay for full-size view + download -->
  <div class="gallery-overlay" id="gallery-overlay" aria-hidden="true">
    <button class="overlay-close" id="overlay-close" aria-label="Close">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    <img class="overlay-img" id="overlay-img" src="" alt="" />
    <a class="overlay-download" id="overlay-download" href="" download aria-label="Download image">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
        <polyline points="7 10 12 15 17 10"></polyline>
        <line x1="12" y1="15" x2="12" y2="3"></line>
      </svg>
      <span>Download</span>
    </a>
  </div>
</section>

<style>
  .gallery-section {
    padding: 64px 16px;
    position: relative;
  }

  .gallery-container {
    max-width: 1440px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .gallery-eyebrow {
    text-align: center;
  }

  /* ── Dense grid: many small thumbnails ── */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 6px;
  }

  .gallery-item {
    margin: 0;
    padding: 0;
    overflow: hidden;
    border-radius: 6px;
    cursor: pointer;
  }

  .gallery-photo {
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    border-radius: 6px;
    filter: brightness(0.92) saturate(0.9);
    transition: filter 0.3s ease, transform 0.3s ease;
  }

  .gallery-photo:hover {
    filter: brightness(1) saturate(1);
    transform: scale(1.03);
  }

  /* ── Overlay ── */
  .gallery-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.92);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .gallery-overlay.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  .overlay-img {
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
    border-radius: 4px;
    opacity: 0;
    transform: scale(0.95);
    transition: opacity 0.3s ease 0.05s, transform 0.3s ease 0.05s;
  }

  .gallery-overlay.is-active .overlay-img {
    opacity: 1;
    transform: scale(1);
  }

  .overlay-close {
    position: absolute;
    top: 24px;
    right: 24px;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.7);
    cursor: pointer;
    padding: 8px;
    transition: color 0.2s ease;
    z-index: 10;
  }

  .overlay-close:hover {
    color: #fff;
  }

  .overlay-download {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    border-radius: 100px;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-family: 'Inter', sans-serif;
    transition: background 0.2s ease, color 0.2s ease;
    white-space: nowrap;
  }

  .overlay-download:hover {
    background: rgba(255, 255, 255, 0.2);
    color: #fff;
  }

  /* ── Mobile: 2 columns ── */
  @media (max-width: 479px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 4px;
    }

    .gallery-section {
      padding: 48px 8px;
    }

    .overlay-download {
      bottom: 24px;
      padding: 10px 20px;
      font-size: 12px;
    }
  }

  /* ── Tablet: 3 columns ── */
  @media (min-width: 480px) and (max-width: 767px) {
    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 5px;
    }
  }

  /* ── Desktop: 4 columns ── */
  @media (min-width: 768px) and (max-width: 1023px) {
    .gallery-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 6px;
    }

    .gallery-section {
      padding: 96px 32px;
    }
  }

  /* ── Large desktop: 5 columns ── */
  @media (min-width: 1024px) {
    .gallery-grid {
      grid-template-columns: repeat(5, 1fr);
      gap: 6px;
    }

    .gallery-section {
      padding: 96px 48px;
    }
  }

  /* ── Extra large: 6 columns ── */
  @media (min-width: 1440px) {
    .gallery-grid {
      grid-template-columns: repeat(6, 1fr);
      gap: 8px;
    }
  }
</style>

<script>
  import { animateFadeUp } from '../lib/gsap-utils';

  document.addEventListener('DOMContentLoaded', () => {
    animateFadeUp('.gallery-section', '.gallery-item', {
      stagger: 0.03,
    });

    // Overlay logic
    const overlay = document.getElementById('gallery-overlay');
    const overlayImg = document.getElementById('overlay-img') as HTMLImageElement;
    const overlayDownload = document.getElementById('overlay-download') as HTMLAnchorElement;
    const overlayClose = document.getElementById('overlay-close');

    if (!overlay || !overlayImg || !overlayDownload || !overlayClose) return;

    // Open overlay on photo click
    document.querySelectorAll('.gallery-item').forEach((item) => {
      item.addEventListener('click', () => {
        const src = (item as HTMLElement).dataset.src || '';
        const alt = (item as HTMLElement).dataset.alt || '';
        overlayImg.src = src;
        overlayImg.alt = alt;
        overlayDownload.href = src;
        // Extract filename for download attribute
        const filename = src.split('/').pop() || 'photo.jpeg';
        overlayDownload.setAttribute('download', filename);
        overlay.classList.add('is-active');
        overlay.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      });
    });

    // Close overlay
    const closeOverlay = () => {
      overlay.classList.remove('is-active');
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };

    overlayClose.addEventListener('click', closeOverlay);
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closeOverlay();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay.classList.contains('is-active')) {
        closeOverlay();
      }
    });
  });
</script>

---
/**
 * Landing page — Post Event Portal
 */

import Layout from '../layouts/Layout.astro';
import EventCalendar from '../components/EventCalendar.astro';
import RoomInAggregate from '../components/RoomInAggregate.astro';
import Briefing from '../components/Briefing.astro';
import HorizontalGallery from '../components/HorizontalGallery.astro';

import '../styles/global.css';
---

<Layout
  title="GILD — Post Event Portal"
  description="We truly appreciated having you at this GILD Edition."
>
  <!-- 01. HERO & 02. MICRO SCROLL -->
  <section class="hero-section">
    <div class="hero-container">
      <div class="hero-left">
        <img src="/assets/logos/logo-gild.png" alt="GILD" class="gild-logo" />
        <h1 class="text-display-l hero-title" style="color: var(--color-fg);">
          <span class="block overflow-hidden">
            <span class="hero-line block">We truly appreciated</span>
          </span>
          <span class="block overflow-hidden">
            <span class="hero-line block">having you at this</span>
          </span>
          <span class="block overflow-hidden">
            <span class="hero-line block">GILD Edition</span>
          </span>
        </h1>
      </div>
      
      <div class="hero-right">
        <p class="text-body-s" style="color: var(--color-fg-muted); margin-bottom: 12px;">
          Presented in partnership with
        </p>
        <a href="https://www.tecla.io/" target="_blank" rel="noopener" class="sponsor-link">
          <img src="/assets/logos/tecla.png" alt="Tecla" class="sponsor-logo" />
        </a>
      </div>
    </div>

    <div class="micro-scroll">
      <div class="scroll-indicator" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </div>
    </div>
  </section>

  <!-- 02.5 HORIZONTAL GALLERY -->
  <div id="hgallery">
    <HorizontalGallery
      images={[
        { src: "/assets/photos/DSCF3426 (1).jpeg", alt: "GILD Edition — Guests arriving" },
        { src: "/assets/photos/GILD-11.jpg", alt: "GILD Edition — Dinner table" },
        { src: "/assets/photos/DSCF3589 (2).jpeg", alt: "GILD Edition — Conversations" },
        { src: "/assets/photos/DSCS6151.jpeg", alt: "GILD Edition — Evening ambiance" },
        { src: "/assets/photos/DSCS6197.jpeg", alt: "GILD Edition — Community" },
        { src: "/assets/photos/DSCS6229.jpeg", alt: "GILD Edition — The room" },
        { src: "/assets/photos/GILD-25.jpg", alt: "GILD Edition — Closing" },
      ]}
      scrollMultiplier={1.2}
    />
  </div>

  <!-- 03. NEXT EDITION + CALENDAR -->
  <section class="calendar-wrapper">
    <div class="calendar-header-text">
      <h2 class="text-display-m" style="color: var(--color-fg); text-align: center;">
        We would be delighted to have you join us for our next edition.
      </h2>
    </div>
    <EventCalendar calendarUrl="https://lu.ma/gild" />
  </section>

  <!-- 04. ROOM IN AGGREGATE -->
  <RoomInAggregate
    eyebrow="THE ROOM, IN AGGREGATE"
    lines={[
      "Engineering Leaders",
      "+12 industries",
      "Four hours.",
      "A room of people actively deploying AI"
    ]}
  />

  <!-- 04.5 BRIEFING -->
  <Briefing
    eyebrow="THE BRIEFING"
    title="A more complete record."
    body="The full briefing extends what's above. Written in the same spirit. Sent only to those who were in the room. Six pages."
    ctaLabel="Download the briefing (PDF) →"
    ctaUrl="/editions/no-01/briefing"
  />

  <!-- 05. SPECIAL THANKS -->
  <section class="thanks-section">
    <div class="thanks-container">
      <h2 class="text-eyebrow" style="color: var(--color-fg-subtle); text-align: center; margin-bottom: 48px;">
        Special Thanks
      </h2>
      <div class="thanks-profile">
        <img src="/assets/photos/varieras.raphael.2026.png" alt="Raphael Varieras" class="thanks-photo" />
        <div class="thanks-info">
          <div class="thanks-name-wrapper">
            <p class="text-body-l" style="color: var(--color-fg); margin: 0;">Raphael Varieras</p>
            <a href="https://www.linkedin.com/in/raphaelvarieras/" target="_blank" rel="noopener" aria-label="Raphael Varieras LinkedIn" class="thanks-social">
              <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                <rect x="2" y="9" width="4" height="12"></rect>
                <circle cx="4" cy="4" r="2"></circle>
              </svg>
            </a>
          </div>
          <img src="/assets/logos/Zello-Logo.png" alt="Zello" class="zello-logo" />
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── HERO ── */
  .hero-section {
    padding: 128px 24px 64px;
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .hero-container {
    max-width: 1280px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 64px;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .gild-logo {
    height: 32px;
    width: auto;
    margin-bottom: 48px;
    filter: brightness(0) invert(1);
  }

  .hero-title {
    margin: 0;
    max-width: 640px;
  }

  .hero-right {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .sponsor-link {
    display: inline-block;
    transition: opacity var(--duration-hover) var(--ease-entrance);
  }

  .sponsor-link:hover {
    opacity: 0.8;
  }

  .sponsor-logo {
    height: 32px;
    width: auto;
    filter: brightness(0) invert(1);
  }

  .micro-scroll {
    max-width: 1280px;
    margin: 64px auto 0;
    width: 100%;
    text-align: center;
  }

  .scroll-indicator {
    color: var(--color-fg-subtle);
    animation: bounce 2s ease-in-out infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); opacity: 0.5; }
    50% { transform: translateY(8px); opacity: 1; }
  }



  /* ── CALENDAR WRAPPER ── */
  .calendar-wrapper {
    padding: 64px 24px;
  }

  .calendar-header-text {
    max-width: 480px;
    margin: 0 auto 32px;
  }

  /* ── SPECIAL THANKS ── */
  .thanks-section {
    padding: 96px 24px 192px;
  }

  .thanks-container {
    max-width: 480px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .thanks-profile {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    text-align: center;
  }

  .thanks-photo {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    filter: grayscale(100%) contrast(1.1);
  }

  .thanks-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .thanks-name-wrapper {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .thanks-social {
    color: var(--color-fg-muted);
    transition: color var(--duration-hover) var(--ease-entrance);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .thanks-social:hover {
    color: var(--color-fg);
  }

  .zello-logo {
    height: 24px;
    width: auto;
    opacity: 0.8;
  }

  /* ── Responsive Layouts ── */
  @media (min-width: 768px) {
    .hero-section {
      padding: 192px 64px 64px;
    }

    .gild-logo {
      margin-bottom: 64px;
    }

    .micro-scroll {
      margin-top: 128px;
    }


  }
</style>

<script>
  import { animateCoverTitle, animateFadeUp } from '../lib/gsap-utils';

  document.addEventListener('DOMContentLoaded', () => {
    // Hero Entrance
    animateCoverTitle('.hero-section', '.hero-line');
    animateFadeUp('.hero-section', '.gild-logo, .hero-right, .micro-scroll', {
      stagger: 0.1,
      delay: 0.4,
    });



    // Sections Entrance
    animateFadeUp('.calendar-wrapper', '.calendar-header-text h2');
    animateFadeUp('.thanks-section', '.thanks-profile', { delay: 0.2 });
  });
</script>
